# Copy to .env.local and set your values.
# For Vercel: Project → Settings → Environment Variables (then redeploy).

# MongoDB (use MongoDB Atlas in production — localhost will NOT work on Vercel)
# Atlas: Network Access → allow 0.0.0.0/0 (or Vercel IPs) so serverless can connect.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=hira-hall

# First admin (super admin) – created automatically when no admins exist
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# SMTP for acceptance/rejection emails (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com
